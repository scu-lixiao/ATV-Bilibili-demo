# ========================================
# Bilibili Live - Environment Configuration Template
# Premium 2025: Sensitive Data Management
# ========================================
#
# IMPORTANT:
# 1. Copy this file to .env (which is gitignored)
# 2. Fill in your actual API keys and credentials
# 3. Never commit .env file to git
#

# Bilibili API Configuration
BILIBILI_APP_KEY=your_app_key_here
BILIBILI_APP_SECRET=your_app_secret_here
BILIBILI_API_BASE_URL=https://api.bilibili.com

# Authentication
BILIBILI_ACCESS_TOKEN=your_access_token_here
BILIBILI_REFRESH_TOKEN=your_refresh_token_here

# Optional: Analytics and Tracking
ANALYTICS_KEY=your_analytics_key_here

# Optional: Push Notifications
PUSH_NOTIFICATION_KEY=your_push_key_here

# Development Settings
DEBUG_MODE=true
LOG_LEVEL=verbose

# Note: Actual implementation should migrate Keys.swift
# to use environment variables or a secure keychain
